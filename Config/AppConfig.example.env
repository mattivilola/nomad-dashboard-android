#!/bin/zsh

# Copy to Config/AppConfig.env for local-only non-secret app config such as the
# ReliefWeb app name and package-restricted client keys such as Google Maps.
# The shipped Android app must not read private provider credentials from this
# file. User-supplied provider credentials belong in the in-app Settings screen
# and are stored only in encrypted device-local storage after install.

export NOMAD_RELIEFWEB_APP_NAME="approved-reliefweb-app-name"
export NOMAD_MAPS_API_KEY="" # Restrict to the Android package name and signing certificate.
