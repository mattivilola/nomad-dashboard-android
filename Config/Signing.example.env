#!/bin/zsh

# Copy to Config/Signing.env and fill in local values.

export NOMAD_APPLICATION_ID="com.iloapps.nomaddashboard"
export NOMAD_DEBUG_APPLICATION_ID_SUFFIX=".dev"

export NOMAD_KEYSTORE_PATH="/absolute/path/to/nomad-dashboard-upload.jks"
export NOMAD_KEYSTORE_PASSWORD="change-me"
export NOMAD_KEY_ALIAS="upload"
export NOMAD_KEY_PASSWORD="change-me"

export NOMAD_PLAY_SERVICE_ACCOUNT_JSON="/absolute/path/to/google-play-service-account.json"
export NOMAD_PLAY_TRACK="internal"

